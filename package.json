{
	"name": "clang-time-tracer",
	"displayName": "Clang Time Tracer",
	"description": "",
	"icon": "doc/icon.png",
	"version": "1.1.1",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Other"
	],
	"publisher": "AnthonyTuffraudGlordim",
	"repository": {
		"type": "git",
		"url": "https://github.com/Glordim/vscode-clang-time-tracer.git"
	},
	"license": "MIT",
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "clang_time_tracer.trace_file",
				"title": "Trace file",
				"category": "Clang Time Tracer"
			},
			{
				"command": "clang_time_tracer.trace_folder",
				"title": "Trace folder",
				"category": "Clang Time Tracer"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "clang_time_tracer.trace_folder",
					"when": "explorerResourceIsFolder",
					"group": "7_modification"
				}
			]
		},
		"configuration": {
			"title": "Clang Time Tracer",
			"properties": {
				"clangTimeTracer.compileCommands.path": {
					"type": "string",
					"default": "build",
					"description": "Path to the compile_commands.json.",
					"format": "path"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.7",
		"@types/vscode": "^1.90.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.27.2",
		"eslint": "^9.39.2",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.52.0"
	}
}